// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  bookings  Booking[]

  @@map("users")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  tag         String
  price       Int
  weight      String
  ingredients String
  description String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("pending") // pending, paid, shipped, delivered, cancelled
  total     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]
  payment    Payment?

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int // price at the time of purchase
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Payment {
  id               String   @id @default(cuid())
  orderId          String   @unique
  stripePaymentId  String
  amount           Int
  status           String   @default("pending") // pending, succeeded, failed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  duration    String
  price       Int
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slots   ActivitySlot[]
  bookings Booking[]

  @@map("activities")
}

model ActivitySlot {
  id         String   @id @default(cuid())
  activityId String
  dateTime   DateTime
  capacity   Int      @default(10)
  booked     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activity Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("activity_slots")
}

model Booking {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  slotId     String
  status     String   @default("pending") // pending, confirmed, cancelled
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  slot     ActivitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@map("bookings")
}
